# ─── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-super-secret-key-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────
DB_NAME=hotelmate_db
DB_USER=hotelmate
DB_PASSWORD=hotelmate_secret
DB_HOST=localhost
DB_PORT=5432

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True

# ─── Stripe ────────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=eur

# ─── PayPal (optional) ─────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ─── SendGrid ──────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@hotelmate.com

# ─── Twilio SMS (optional) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Platform ──────────────────────────────────────────────────────────────
PLATFORM_COMMISSION=0.90
